<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IponHub - Security Recovery</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@800&family=Inter:wght@500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --white: #ffffff;
            --neon-green: #39FF14;
            --brand-green: #2E7D32;
            --logo-red: #EA4335;
            --logo-yellow: #FBBC05;
            --logo-blue: #4285F4;
            --cloud-shadow: rgba(129, 212, 250, 0.6);
            --sky-top: #40C4FF;
            --sky-bottom: #B3E5FC;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; min-height: 100vh; display: flex; flex-direction: column; align-items: center; overflow-x: hidden; }

        /* 🌦️ 4D WEATHER COVER (CEBU SYNC) */
        .cover-area {
            width: 100%; height: 160px; position: relative; z-index: 1;
            border-top: 5px solid var(--white); border-bottom: 5px solid var(--white);
            background: linear-gradient(180deg, var(--sky-top) 0%, var(--sky-bottom) 100%);
            overflow: hidden; transition: all 1.5s ease;
        }

        .lightning-flash { position: absolute; width: 100%; height: 100%; background: white; opacity: 0; z-index: 10; pointer-events: none; }
        @keyframes flashAnim { 0% { opacity: 0; } 10% { opacity: 0.8; } 15% { opacity: 0; } 20% { opacity: 0.7; } 25% { opacity: 0; } }

        .rain-layer { position: absolute; width: 100%; height: 100%; z-index: 2; display: none; }
        .rain-layer.active { display: block; }
        .rain-layer::before {
            content: ''; position: absolute; width: 100%; height: 100%;
            background-image: linear-gradient(to bottom, rgba(255,255,255,0.2) 15%, transparent 15%);
            background-size: 2px 25px; animation: rainDrop 0.15s linear infinite;
        }
        @keyframes rainDrop { from { transform: translateY(-25px); } to { transform: translateY(25px); } }

        .vector-cloud {
            position: absolute; background: var(--white); border-radius: 50px;
            box-shadow: inset 0 -15px 0 var(--cloud-shadow); animation: vectorMove var(--speed) linear infinite;
        }
        .vector-cloud::before, .vector-cloud::after { content: ''; position: absolute; background: inherit; border-radius: 50%; box-shadow: inherit; }
        .v1 { width: 180px; height: 60px; top: 15%; --speed: 35s; left: -200px; }
        .v1::before { width: 90px; height: 90px; top: -50px; left: 30px; }
        .v1::after { width: 70px; height: 70px; top: -30px; right: 20px; }
        @keyframes vectorMove { from { transform: translateX(-100px); } to { transform: translateX(calc(100vw + 300px)); } }

        /* 📱 TABLET & BRAND SHINE */
        .mini-tablet { background: #1A1A1A; width: 138px; height: 82px; border-radius: 12px; padding: 5px; box-shadow: 0 15px 35px rgba(0,0,0,0.4); display: flex; justify-content: center; align-items: center; position: relative; z-index: 5; margin-top: -41px; }
        .tablet-screen { background: var(--white); width: 100%; height: 100%; border-radius: 9px; display: flex; justify-content: center; align-items: center; border: 0.5px solid #000; overflow: hidden; position: relative; }
        
        .brand-wrapper { position: relative; display: inline-block; }
        .brand-name { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 25px; letter-spacing: -1.5px; color: var(--brand-green); position: relative; z-index: 1; }
        .brand-name .h-red { color: var(--logo-red); }
        .brand-name .u-yellow { color: var(--logo-yellow); }
        .brand-name .b-blue { color: var(--logo-blue); }
        
        .shine-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; mix-blend-mode: overlay; background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0) 40%, rgba(255,255,255,1) 50%, rgba(255,255,255,0) 60%, rgba(255,255,255,0) 100%); background-size: 200% 100%; animation: brandShine 3s ease-in-out infinite; }
        @keyframes brandShine { 0% { background-position: 200% 0; } 45% { background-position: -100% 0; } 100% { background-position: -100% 0; } }

        /* 📦 RESET FORM */
        .outer-layer {
            width: 92%; max-width: 380px;
            margin-top: 40px; margin-bottom: 50px;
            background: var(--neon-green); padding: 4px; border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1); z-index: 10;
        }

        .container-box { background: var(--white); border-radius: 20px; overflow: hidden; }
        .form-banner { padding: 35px 25px 10px 25px; text-align: center; }
        .form-banner h2 { font-family: 'Montserrat', sans-serif; font-size: 20px; color: #1A1A1A; margin-bottom: 8px; letter-spacing: -0.5px; }
        .form-banner p { font-size: 12px; color: #546E7A; font-weight: 500; line-height: 1.5; }

        .form-content { padding: 25px 30px 40px 30px; }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 10px; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; color: #95A5A6; letter-spacing: 0.5px; }
        .form-control { width: 100%; padding: 14px; border: 1.5px solid #E5E7EB; border-radius: 12px; background-color: #F9FAFB; font-size: 14px; outline: none; transition: 0.2s; }
        .form-control:focus { border-color: var(--brand-green); background-color: #fff; box-shadow: 0 0 0 4px rgba(46, 125, 50, 0.05); }

        .btn-action { width: 100%; padding: 16px; background-color: var(--brand-green); color: white; border: none; border-radius: 12px; font-size: 15px; font-family: 'Montserrat', sans-serif; font-weight: 700; cursor: pointer; box-shadow: 0 8px 20px rgba(46, 125, 50, 0.15); transition: 0.3s; }
        .btn-action:active { transform: scale(0.98); }

        .form-footer { text-align: center; padding: 25px; font-size: 13px; background: #F9F9F9; border-top: 1px solid #EEE; }
        .form-footer a { color: var(--brand-green); text-decoration: none; font-weight: 700; }

        /* 🔒 MODAL STYLING */
        .modal { display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); }
        .modal-content { background: white; width: 90%; max-width: 360px; margin: 15% auto; border-radius: 20px; padding: 35px 30px; position: relative; animation: slideUp 0.4s ease; }
        @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .close-modal { position: absolute; right: 20px; top: 15px; font-size: 28px; cursor: pointer; color: #95A5A6; line-height: 1; }
        .modal-header { text-align: center; margin-bottom: 25px; }
        .modal-header h3 { font-family: 'Montserrat', sans-serif; font-size: 18px; color: #1A1A1A; }
    </style>
</head>
<body>

    <div class="cover-area" id="cebu-sky">
        <div class="lightning-flash" id="lightning"></div>
        <div class="rain-layer" id="rain"></div>
        <div id="cloud-container">
            <div class="vector-cloud v1"></div>
            <div class="vector-cloud v1" style="animation-delay: -10s; top: 35%; opacity: 0.7;"></div>
        </div>
    </div>

    <div class="mini-tablet">
        <div class="tablet-screen">
            <div class="brand-wrapper">
                <div class="brand-name">Ipon<span class="h-red">H</span><span class="u-yellow">u</span><span class="b-blue">b</span></div>
                <div class="shine-overlay"></div>
            </div>
        </div>
    </div>

    <div class="outer-layer">
        <div class="container-box">
            <div class="form-banner">
                <h2>Account Recovery</h2>
                <p>Provide your registered email address to initiate the secure credential reset process.</p>
            </div>

            <div class="form-content">
                <form id="forgotForm">
                    <div class="input-group">
                        <label>Corporate Email Address</label>
                        <input type="email" class="form-control" id="reset-email" required placeholder="">
                    </div>
                    <button type="submit" class="btn-action">AUTHENTICATE EMAIL</button>
                </form>
            </div>

            <div class="form-footer">
                <a href="frontend/login.html">Return to Login</a>
            </div>
        </div>
    </div>

    <div id="pw-modal" class="modal">
        <div class="modal-content">
            <span class="close-modal" id="close-pw">&times;</span>
            <div class="modal-header">
                <h3>Update Credentials</h3>
            </div>
            <form id="newPwForm">
                <div class="input-group">
                    <label>New Secure Password</label>
                    <input type="password" class="form-control" id="n-pass" required placeholder="••••••••">
                </div>
                <div class="input-group">
                    <label>Verify New Password</label>
                    <input type="password" class="form-control" id="c-n-pass" required placeholder="••••••••">
                </div>
                <button type="submit" class="btn-action">SAVE UPDATED PASSWORD</button>
            </form>
        </div>
    </div>

    <script>
        // --- CEBU WEATHER ENGINE ---
        async function updateWeatherEngine() {
            const sky = document.getElementById('cebu-sky');
            const rain = document.getElementById('rain');
            const lightning = document.getElementById('lightning');
            try {
                const resp = await fetch('https://api.openweathermap.org/data/2.5/weather?q=Cebu&appid=da0650965e6d628f844b24131df33246');
                const data = await resp.json();
                const condition = data.weather[0].main; 
                const hour = new Date().getHours();
                let isNight = (hour >= 18 || hour < 5);
                
                if (isNight) sky.style.background = "linear-gradient(180deg, #0B0E14 0%, #1A237E 100%)";
                else if (hour >= 16 && hour < 18) sky.style.background = "linear-gradient(180deg, #E64A19 0%, #FFB74D 100%)";
                else sky.style.background = "linear-gradient(180deg, #40C4FF 0%, #B3E5FC 100%)";
                
                if (condition === 'Rain' || condition === 'Drizzle' || condition === 'Thunderstorm') {
                    rain.classList.add('active');
                    if(condition === 'Thunderstorm') {
                        setInterval(() => { if (Math.random() > 0.8) { lightning.style.animation = 'flashAnim 0.4s ease-out'; setTimeout(() => lightning.style.animation = '', 400); } }, 5000);
                    }
                }
            } catch (e) { console.log("System Sync: Offline"); }
        }
        updateWeatherEngine();

        // --- MODAL & FORM LOGIC ---
        const forgotForm = document.getElementById('forgotForm');
        const pwModal = document.getElementById('pw-modal');
        const closePw = document.getElementById('close-pw');
        const newPwForm = document.getElementById('newPwForm');

        forgotForm.onsubmit = (e) => {
            e.preventDefault();
            pwModal.style.display = "block";
        };

        closePw.onclick = () => { pwModal.style.display = "none"; };

        newPwForm.onsubmit = (e) => {
            e.preventDefault();
            const nPass = document.getElementById('n-pass').value;
            const cNPass = document.getElementById('c-n-pass').value;
            if (nPass !== cNPass) { alert("Verification failed. Passwords do not match."); return; }
            alert("Security credentials updated. Redirecting to terminal...");
            window.location.href = "login.html";
        };

        window.onclick = (event) => { if (event.target == pwModal) pwModal.style.display = "none"; }
    </script>
</body>
</html>
